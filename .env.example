# Dashboard auth
AUTH_SECRET=replace-with-a-long-random-secret
DASHBOARD_ALLOWED_PHONE_NUMBERS=+15551234567
# Leave empty for dashboard.wayfloat.com. Set to /dashboard only if mounting under wayfloat.com/dashboard.
NEXT_PUBLIC_DASHBOARD_BASE_PATH=
NEXT_PUBLIC_DASHBOARD_FIREBASE_API_KEY=
NEXT_PUBLIC_DASHBOARD_FIREBASE_AUTH_DOMAIN=app-performance-dashboard.firebaseapp.com
NEXT_PUBLIC_DASHBOARD_FIREBASE_PROJECT_ID=app-performance-dashboard
NEXT_PUBLIC_DASHBOARD_FIREBASE_APP_ID=
# Optional comma-separated IP/CIDR allowlist (e.g. your home network). When set,
# all requests from other IPs get 403. Leave empty to disable. Prefer also
# configuring Azure App Service "Access restrictions" for platform-level blocking.
# Example: DASHBOARD_ALLOWED_IPS=203.0.113.45,198.51.100.0/24
DASHBOARD_ALLOWED_IPS=

# Dedicated dashboard Firebase project for snapshots
DASHBOARD_FIREBASE_PROJECT_ID=dashboard-project-id
DASHBOARD_FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
DASHBOARD_FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# App Store Connect
APP_STORE_CONNECT_KEY_ID=ABC123DEFG
APP_STORE_CONNECT_ISSUER_ID=00000000-0000-0000-0000-000000000000
APP_STORE_CONNECT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
APP_STORE_CONNECT_VENDOR_NUMBER=12345678

# Google AdMob reporting
GOOGLE_ADMOB_CLIENT_ID=
GOOGLE_ADMOB_CLIENT_SECRET=
GOOGLE_ADMOB_REFRESH_TOKEN=
GOOGLE_ADMOB_PUBLISHER_ACCOUNT=accounts/pub-0000000000000000

# Puzzle Canvas source Firebase + app config
PUZZLE_CANVAS_FIREBASE_PROJECT_ID=puzzle-canvas-project
PUZZLE_CANVAS_FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
PUZZLE_CANVAS_FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Numeric GA4 property ID. Grant the Firebase service-account email Viewer access to this GA4 property.
PUZZLE_CANVAS_GA4_PROPERTY_ID=
PUZZLE_CANVAS_APPLE_APP_ID=
PUZZLE_CANVAS_ADMOB_APP_ID=
PUZZLE_CANVAS_ADS_START_DATE=2024-01-01
PUZZLE_CANVAS_DOWNLOADS_SOURCE=firestore-users
PUZZLE_CANVAS_USERS_COLLECTION=users
PUZZLE_CANVAS_USER_CREATED_AT_FIELD=createdAt
PUZZLE_CANVAS_USER_SANDBOX_FIELD=subscriptionDetails.environment
PUZZLE_CANVAS_USER_SANDBOX_VALUE=Sandbox
# User doc flag set once a user exits the tutorial episodes (defaults to tutorialPassed=true)
PUZZLE_CANVAS_USER_ONBOARDED_FIELD=tutorialPassed
PUZZLE_CANVAS_USER_ONBOARDED_VALUE=true
PUZZLE_CANVAS_USER_TOTAL_EPISODES_COMPLETED_FIELD=totalEpisodesCompleted
PUZZLE_CANVAS_ACTIVITY_COLLECTION=userActivity
PUZZLE_CANVAS_ACTIVITY_USER_FIELD=userId
PUZZLE_CANVAS_ACTIVITY_TIMESTAMP_FIELD=lastActiveAt
PUZZLE_CANVAS_ACTIVITY_TIMESTAMP_TYPE=timestamp
PUZZLE_CANVAS_ENTITLEMENTS_COLLECTION=entitlements
PUZZLE_CANVAS_ENTITLEMENT_STATUS_FIELD=status
PUZZLE_CANVAS_ENTITLEMENT_PRODUCT_FIELD=productId
PUZZLE_CANVAS_ENTITLEMENT_ORIGINAL_PURCHASE_DATE_FIELD=subscriptionDetails.originalPurchaseDate
PUZZLE_CANVAS_ENTITLEMENT_EXPIRY_DATE_FIELD=subscriptionDetails.expiryDate
PUZZLE_CANVAS_ENTITLEMENT_ACTIVE_VALUE=active
PUZZLE_CANVAS_MONTHLY_PRODUCT_IDS=
PUZZLE_CANVAS_ANNUAL_PRODUCT_IDS=
PUZZLE_CANVAS_MONTHLY_PRICE_USD=2.99
PUZZLE_CANVAS_PURCHASES_COLLECTION=purchases
PUZZLE_CANVAS_PURCHASE_TIMESTAMP_FIELD=purchasedAt
PUZZLE_CANVAS_PURCHASE_TIMESTAMP_TYPE=timestamp
PUZZLE_CANVAS_PURCHASE_AMOUNT_FIELD=priceUsd
PUZZLE_CANVAS_PURCHASE_PRODUCT_FIELD=productId
PUZZLE_CANVAS_PURCHASE_PRODUCT_TYPE_FIELD=productType
PUZZLE_CANVAS_PURCHASE_CONSUMABLE_VALUE=consumable
PUZZLE_CANVAS_GOLD_PACK_PRODUCT_IDS=
PUZZLE_CANVAS_GOLD_PACK_PRICE_USD=
PUZZLE_CANVAS_GOLD_PACK_KIND=
PUZZLE_CANVAS_NEW_CANVAS_PRODUCT_IDS=
PUZZLE_CANVAS_NEW_CANVAS_PRICE_USD=
PUZZLE_CANVAS_NEW_CANVAS_KIND=

# Savory Advisor source Firebase + app config (Firestore only). Project: savoryadvisor-a5a8a
# Add credentials with: node scripts/load-service-account-env.js SAVORY_ADVISOR /path/to/savoryadvisor-a5a8a-adminsdk.json
SAVORY_ADVISOR_FIREBASE_PROJECT_ID=savoryadvisor-a5a8a
SAVORY_ADVISOR_FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
SAVORY_ADVISOR_FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
SAVORY_ADVISOR_DOWNLOADS_SOURCE=firestore-users
SAVORY_ADVISOR_USERS_COLLECTION=users
SAVORY_ADVISOR_ACTIVITY_COLLECTION=users
SAVORY_ADVISOR_ACTIVITY_USER_FIELD=__docId
SAVORY_ADVISOR_ACTIVITY_TIMESTAMP_FIELD=lastLoginAt
SAVORY_ADVISOR_ACTIVITY_TIMESTAMP_TYPE=timestamp
SAVORY_ADVISOR_ENTITLEMENTS_COLLECTION=users
SAVORY_ADVISOR_ENTITLEMENT_STATUS_FIELD=isSubscribed
SAVORY_ADVISOR_ENTITLEMENT_ACTIVE_VALUE=true
SAVORY_ADVISOR_ENTITLEMENT_PRODUCT_FIELD=subscriptionDetails.productId
SAVORY_ADVISOR_ENTITLEMENT_ORIGINAL_PURCHASE_DATE_FIELD=subscriptionDetails.originalPurchaseDate
SAVORY_ADVISOR_ENTITLEMENT_EXPIRY_DATE_FIELD=subscriptionDetails.expiryDate
SAVORY_ADVISOR_MONTHLY_PRODUCT_IDS=SavoryClub.MonthlyPlan
SAVORY_ADVISOR_ANNUAL_PRODUCT_IDS=SavoryClub.AnnualPlan
SAVORY_ADVISOR_MONTHLY_PRICE_USD=4.99
SAVORY_ADVISOR_ANNUAL_PRICE_USD=49.99
# Consumables (Assist Refill) feed Accumulated IAP Sales; read from iapTransactions.
SAVORY_ADVISOR_ASSIST_REFILL_MEMBER_PRODUCT_IDS=DiscoveryPack.Member
SAVORY_ADVISOR_ASSIST_REFILL_MEMBER_PRICE_USD=1.99
SAVORY_ADVISOR_ASSIST_REFILL_NON_MEMBER_PRODUCT_IDS=DiscoveryPack.Guest
SAVORY_ADVISOR_ASSIST_REFILL_NON_MEMBER_PRICE_USD=1.99

# Receipt Cam source Firebase + app config. Project: receipt-cam-app
# Add credentials with: node scripts/load-service-account-env.js RECEIPT_CAM /path/to/receipt-cam-adminsdk.json
RECEIPT_CAM_FIREBASE_PROJECT_ID=receipt-cam-app
RECEIPT_CAM_FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
RECEIPT_CAM_FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
RECEIPT_CAM_APPLE_APP_ID=6746401835
# Use App Store first-time downloads as the true downloads number (Firestore
# users undercounts: pre-2.1 sign-in dropoffs never created a user doc).
RECEIPT_CAM_DOWNLOADS_SOURCE=app-store
RECEIPT_CAM_USERS_COLLECTION=users
RECEIPT_CAM_USER_CREATED_AT_FIELD=createdAt
# Activity lives on the user docs (lastActiveAt) — there is no userActivity collection.
RECEIPT_CAM_ACTIVITY_COLLECTION=users
RECEIPT_CAM_ACTIVITY_USER_FIELD=__docId
RECEIPT_CAM_ACTIVITY_TIMESTAMP_FIELD=lastActiveAt
RECEIPT_CAM_ACTIVITY_TIMESTAMP_TYPE=timestamp
RECEIPT_CAM_ENTITLEMENTS_COLLECTION=users
RECEIPT_CAM_ENTITLEMENT_STATUS_FIELD=isPro
RECEIPT_CAM_ENTITLEMENT_PRODUCT_FIELD=iapData.productId
RECEIPT_CAM_ENTITLEMENT_EXPIRY_DATE_FIELD=iapData.latestExpiresDateMs
RECEIPT_CAM_ENTITLEMENT_ACTIVE_VALUE=true
# New products first, grandfathered products second.
RECEIPT_CAM_MONTHLY_PRODUCT_IDS=ReceiptCam.MonthlyPlan.4,ReceiptCam.MonthlyPlan.3
RECEIPT_CAM_ANNUAL_PRODUCT_IDS=ReceiptCam.AnnualPlan.3,ReceiptCam.AnnualPlan.2
# Per-product prices (grandfathered products renew at old prices).
RECEIPT_CAM_PRODUCT_PRICES_USD=ReceiptCam.MonthlyPlan.4:2.99,ReceiptCam.MonthlyPlan.3:1.99,ReceiptCam.AnnualPlan.3:24.99,ReceiptCam.AnnualPlan.2:19.99
# Fallbacks when a product is missing from the map above.
RECEIPT_CAM_MONTHLY_PRICE_USD=2.99
RECEIPT_CAM_ANNUAL_PRICE_USD=24.99
